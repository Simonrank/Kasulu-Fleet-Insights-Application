# Data source: google_sheets | wialon | both
DATA_SOURCE=google_sheets

# Wialon — used when DATA_SOURCE is wialon or both
WIALON_API_URL=https://hst-api.wialon.com/wialon/ajax.html
WIALON_TOKEN=
WIALON_REPORT_RESOURCE_ID=
WIALON_REPORT_TEMPLATE_ID=
WIALON_REPORT_GROUP_ID=
# Optional: table label substring to pick fleet stats table (e.g. Statistics)
WIALON_REPORT_TABLE_LABEL=
# Max calendar days to pull via daily reports (matches sheet sync window by default)
WIALON_REPORT_MAX_DAYS=7

# Current Mobile Status — live asset table on dashboard (ControlRoom report)
WIALON_MOBILE_STATUS_RESOURCE_ID=
WIALON_MOBILE_STATUS_TEMPLATE_ID=
WIALON_MOBILE_STATUS_OBJECT_ID=
# WIALON_MOBILE_STATUS_TABLE_LABEL=

# Show Google Sheets / Wialon toggle in UI when both sources are configured
NEXT_PUBLIC_DUAL_SOURCE=false

# Google Sheets — required for google_sheets mode
GOOGLE_SHEETS_SPREADSHEET_ID=
# On Vercel: paste the full service account JSON as one line (file path won't work in production)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-service-account.json
GOOGLE_SHEETS_FLEET_RANGE=Sheet1!A:M
GOOGLE_SHEETS_REGISTER_RANGE=Sheet3!A:B
GOOGLE_SHEETS_SYNC_DAYS=7

# Neon Postgres
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# App labels (optional)
NEXT_PUBLIC_APP_NAME=
NEXT_PUBLIC_ORG_LABEL=
NEXT_PUBLIC_OPS_AREA=

# KPI targets (optional — omit to hide variance comparisons)
# KPI_TARGET_UTILIZATION=
# KPI_TARGET_KM_PER_LITER=
# KPI_TARGET_LITERS_PER_HOUR=

SYNC_INTERVAL_MINUTES=15
CRON_SECRET=

# NextAuth — set AUTH_SECRET in production. Do NOT set AUTH_URL to localhost on Vercel;
# leave AUTH_URL unset on Vercel (trustHost uses the deployment URL automatically).
AUTH_SECRET=
# AUTH_URL=http://localhost:3000
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=
